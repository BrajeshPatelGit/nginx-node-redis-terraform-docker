{
  "AWSEBDockerrunVersion": 2,
  "containerDefinitions": [
    {
      "name": "redis",
      "image": "redis:8-alpine",
      "essential": false,
      "memory": 128,
      "portMappings": [
        { "containerPort": 6379 }
      ]
    },
    {
      "name": "web1",
      "image": "229209687346.dkr.ecr.us-east-1.amazonaws.com/bak-ng-red-nd-ter-doc",
      "essential": false,
      "links": ["redis"],
      "memory": 256,
      "portMappings": [
        { "containerPort": 5000 }
      ]
    },
    {
      "name": "web2",
      "image": "229209687346.dkr.ecr.us-east-1.amazonaws.com/bak-ng-red-nd-ter-doc",
      "essential": false,
      "links": ["redis"],
      "memory": 256,
      "portMappings": [
        { "containerPort": 5000 }
      ]
    },
    {
      "name": "nginx-proxy",
      "image": "229209687346.dkr.ecr.us-east-1.amazonaws.com/web-ng-red-nd-ter-doc",
      "essential": true,
      "memory": 128,
      "links": ["web1", "web2"],
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 80
        }
      ]
    }
  ]
}
